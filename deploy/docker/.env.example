# SentinelMail Gateway — local stack configuration
# Copy to deploy/docker/.env and adjust before `make up`.

# ----- Image / container -----
SENTINELMAIL_IMAGE=sentinelmail/api:dev
SENTINELMAIL_WEB_IMAGE=sentinelmail/web:dev
SENTINELMAIL_WORKER_IMAGE=sentinelmail/worker:dev
COMPOSE_PROJECT_NAME=sentinelmail

# ----- Bind ports (host side) -----
SMG_SMTP_PORT=25
SMG_SUBMISSION_PORT=587
SMG_HTTP_PORT=8080
SMG_HTTPS_PORT=8443
SMG_API_PORT=8081

# ----- Database -----
POSTGRES_DB=sentinelmail
POSTGRES_USER=sentinelmail
POSTGRES_PASSWORD=change-me-in-real-env

# ----- Redis -----
REDIS_URL=redis://redis:6379/0

# ----- API secrets -----
# Generate: openssl rand -hex 32
API_SESSION_SECRET=
API_AUDIT_HMAC_KEY=

# ----- Mail plane -----
POSTFIX_MYHOSTNAME=mx.example.com
POSTFIX_MYNETWORKS=127.0.0.0/8 10.0.0.0/8
RSPAMD_PASSWORD=change-me
RSPAMD_CONTROLLER_PASSWORD=change-me

# ----- Threat feeds -----
SPAMHAUS_DQS_KEY=
URLHAUS_API_KEY=
OPENPHISH_FEED_URL=

# ----- Data persistence -----
DATA_FOLDER=./data
